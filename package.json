{
  "name": "homebridge-ha-virtual-devices",
  "displayName": "Homebridge HA Virtual Devices",
  "type": "module",
  "version": "1.1.4",
  "description": "Automatically exposes Home Assistant environmental sensors as read-only HomeKit thermostat accessories through Homebridge.",
  "author": {
    "name": "Fabrice Montant"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/fmontant/homebridge-ha-virtual-devices#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmontant/homebridge-ha-virtual-devices.git"
  },
  "bugs": {
    "url": "https://github.com/fmontant/homebridge-ha-virtual-devices/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homekit",
    "home-assistant",
    "homeassistant",
    "apple-home",
    "thermostat",
    "temperature",
    "humidity",
    "environmental-sensor",
    "websocket",
    "smart-home"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "homebridge-ui/public",
    "homebridge-ui/server.js",
    "docs/images/banner.png",
    "config.schema.json",
    "README.md",
    "README.fr.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "build:ui": "npm --prefix homebridge-ui run build && rm -f homebridge-ui/public/assets/index-*.js homebridge-ui/public/assets/index-*.css && cp -R homebridge-ui/dist/. homebridge-ui/public/",
    "build:all": "npm run build && npm run build:ui",
    "lint": "eslint . --max-warnings=0",
    "prepublishOnly": "npm run lint && npm run build:all",
    "watch": "npm run build && npm link && nodemon",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.5",
    "homebridge-lib": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "homebridge": "^2.0.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
